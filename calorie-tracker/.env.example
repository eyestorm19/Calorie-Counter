# Firebase Configuration
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Application Settings
VITE_APP_NAME=Apollo Calorie Tracker
VITE_APP_VERSION=1.0.0
VITE_APP_MODE=development

# AI API Configuration
# Only set this in production. In development, the app connects to localhost:11434 directly.
# For development: Comment out this line to use local Ollama
# For production: Uncomment and set to your Firebase Function URL
# VITE_AI_API_ENDPOINT=https://us-central1-your-project-id.cloudfunctions.net/generateActivity 