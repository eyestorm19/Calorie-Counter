FROM ollama/ollama:0.6.0

# Set environment variables
ENV OLLAMA_HOST=0.0.0.0:8080
ENV OLLAMA_KEEP_ALIVE=300
ENV OLLAMA_NUM_PARALLEL=4

# Set the default model (can be overridden at runtime)
ENV OLLAMA_MODEL=mistral

# Create directories for models and ensure correct permissions
RUN mkdir -p /root/.ollama/models && \
    chmod -R 755 /root/.ollama

# Expose the HTTP port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8080/api/tags || exit 1

# Run Ollama
CMD ["ollama", "serve"] 